<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linearLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/filmImageView"
        android:layout_width="142dp"
        android:layout_height="155dp"
        android:layout_marginStart="11dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="25dp"
        android:src="@drawable/interstellar"
        app:layout_constraintBottom_toBottomOf="@+id/genreSpinner"
        app:layout_constraintEnd_toStartOf="@+id/genreSpinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <EditText
        android:id="@+id/titleEditText"
        android:layout_width="189dp"
        android:layout_height="58dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="11dp"
        android:hint="@string/hint_title"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/directorEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.214"
        app:layout_constraintStart_toEndOf="@+id/selectImageButton"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/selectImageButton"
        android:layout_width="153dp"
        android:layout_height="54dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/select_image_button_text"
        android:textSize="12dp"
        app:layout_constraintBottom_toTopOf="@+id/directorEditText"
        app:layout_constraintStart_toEndOf="@+id/captureImageButton"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/captureImageButton"
        android:layout_width="171dp"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:text="@string/capture_image_button_text"
        android:textSize="12dp"
        app:layout_constraintBottom_toTopOf="@+id/directorEditText"
        app:layout_constraintStart_toEndOf="@+id/filmImageView"
        app:layout_constraintTop_toTopOf="parent" />

    <Spinner
        android:id="@+id/genreSpinner"
        android:layout_width="158dp"
        android:layout_height="59dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="1dp"
        app:layout_constraintBottom_toBottomOf="@+id/yearEditText"
        app:layout_constraintEnd_toStartOf="@+id/yearEditText"
        app:layout_constraintStart_toEndOf="@+id/filmImageView"
        app:layout_constraintTop_toTopOf="@+id/yearEditText"
        app:layout_constraintVertical_bias="1.0" />

    <EditText
        android:id="@+id/urlEditText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="37dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="2dp"
        android:hint="@string/hint_url"
        android:inputType="textUri"
        app:layout_constraintBottom_toTopOf="@+id/commentsEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/filmImageView"
        app:layout_constraintTop_toBottomOf="@+id/yearEditText" />

    <Spinner
        android:id="@+id/formatSpinner"
        android:layout_width="186dp"
        android:layout_height="58dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="3dp"
        app:layout_constraintBottom_toTopOf="@+id/urlEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.214"
        app:layout_constraintStart_toEndOf="@+id/yearEditText"
        app:layout_constraintTop_toBottomOf="@+id/directorEditText"
        app:layout_constraintVertical_bias="0.0" />

    <EditText
        android:id="@+id/yearEditText"
        android:layout_width="166dp"
        android:layout_height="58dp"
        android:layout_marginEnd="232dp"
        android:layout_marginBottom="56dp"
        android:hint="@string/hint_year"
        android:inputType="number"
        app:layout_constraintBottom_toTopOf="@+id/commentsEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/genreSpinner" />

    <EditText
        android:id="@+id/directorEditText"
        android:layout_width="518dp"
        android:layout_height="51dp"
        android:layout_marginTop="76dp"
        android:layout_marginBottom="66dp"
        android:hint="@string/hint_director"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="@+id/yearEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.852"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/filmImageView"
        app:layout_constraintVertical_bias="0.791" />

    <EditText
        android:id="@+id/commentsEditText"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginBottom="8dp"
        android:hint="@string/hint_comments"
        android:inputType="textMultiLine"
        android:minLines="3"
        app:layout_constraintBottom_toTopOf="@+id/cancelButton"
        app:layout_constraintEnd_toEndOf="@+id/urlEditText"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/urlEditText" />

    <Button
        android:id="@+id/cancelButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="123dp"
        android:layout_marginEnd="123dp"
        android:layout_marginBottom="8dp"
        android:text="@string/cancel_button_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/saveButton"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="184dp"
        android:layout_marginBottom="8dp"
        android:text="@string/save_button_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
