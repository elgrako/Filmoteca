<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/webButton"
        android:layout_width="411dp"
        android:layout_height="65dp"
        android:layout_marginTop="512dp"
        android:text="@string/web_button_text"
        android:textColorLink="@color/design_default_color_primary"
        app:cornerRadius="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/volverButton"
        android:layout_width="412dp"
        android:layout_height="73dp"
        android:text="@string/volver_button_text"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/soporteButton"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/soporteButton"
        android:layout_width="411dp"
        android:layout_height="79dp"
        android:text="@string/soporte_button_text"
        app:cornerRadius="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/webButton" />

    <TextView
        android:id="@+id/creador"
        android:layout_width="220dp"
        android:layout_height="35dp"
        android:text="@string/creador_text"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/volverButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.575"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.043" />

    <ImageView
        android:id="@+id/imgabout"
        android:layout_width="362dp"
        android:layout_height="280dp"
        android:layout_marginBottom="312dp"
        android:src="@drawable/cinema_academy_about"
        app:layout_constraintBottom_toBottomOf="@+id/volverButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        tools:srcCompat="@tools:sample/avatars" />

</androidx.constraintlayout.widget.ConstraintLayout>