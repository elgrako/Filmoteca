<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <Button
        android:id="@+id/RegisterButton"
        android:layout_width="140dp"
        android:layout_height="0dp"
        android:layout_marginBottom="174dp"
        android:text="Registrarse"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/loginButton" />

    <EditText
        android:id="@+id/UserField"
        android:layout_width="222dp"
        android:layout_height="0dp"
        android:layout_marginBottom="39dp"
        android:drawableStart="@drawable/usuarioescalado"
        android:ems="10"
        android:hint="   Username"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/PasswordField"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/usuarioIcon" />

    <EditText
        android:id="@+id/PasswordField"
        android:layout_width="222dp"
        android:layout_height="0dp"
        android:layout_marginBottom="51dp"
        android:drawableStart="@drawable/llave"
        android:ems="10"
        android:hint="   Password"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/loginButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/UserField" />

    <Button
        android:id="@+id/loginButton"
        android:layout_width="140dp"
        android:layout_height="0dp"
        android:layout_marginBottom="32dp"
        android:text="Ingresar"
        app:layout_constraintBottom_toTopOf="@+id/RegisterButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/PasswordField" />

    <ImageView
        android:id="@+id/usuarioIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:layout_marginBottom="56dp"
        app:layout_constraintBottom_toTopOf="@+id/UserField"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

</androidx.constraintlayout.widget.ConstraintLayout>